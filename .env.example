
# ============================================================
# Projeto: Pipeline Lakehouse de Dados Abertos da Câmara
# Arquivo: .env.example
#
# Este arquivo contém exemplos de variáveis de ambiente usadas
# para parametrizar o projeto.
#
# Para uso local, copie este arquivo para:
#
#   .env
#
# e ajuste os valores conforme seu ambiente.
#
# Nunca versionar o arquivo .env real com credenciais.
# ============================================================


# ============================================================
# Ambiente
# ============================================================

# Ambiente de execução: local, dev, staging ou prod
ENVIRONMENT=local

# Nome lógico do projeto
PROJECT_NAME=dados_abertos_camara_lakehouse

# Timezone usada em logs e processamentos
PROJECT_TIMEZONE=America/Sao_Paulo


# ============================================================
# API Dados Abertos Câmara
# ============================================================

# URL base da API pública da Câmara dos Deputados
CAMARA_API_BASE_URL=https://dadosabertos.camara.leg.br/api/v2

# Timeout das requisições HTTP, em segundos
CAMARA_API_TIMEOUT_SECONDS=30

# Número máximo de tentativas em caso de falha temporária
CAMARA_API_MAX_RETRIES=3

# Tempo de espera entre tentativas, em segundos
CAMARA_API_RETRY_SLEEP_SECONDS=5

# Tamanho de página usado em endpoints paginados
CAMARA_API_PAGE_SIZE=100

# User-Agent para chamadas à API
CAMARA_API_USER_AGENT=dados-abertos-camara-lakehouse/0.1.0


# ============================================================
# Storage / Data Lake
# ============================================================

# Caminho base do Data Lake.
#
# Exemplo local:
# BASE_STORAGE_PATH=file:/tmp/dados_abertos_camara
#
# Exemplo Azure Data Lake Gen2:
# BASE_STORAGE_PATH=abfss://<container>@<storage-account>.dfs.core.windows.net
#
BASE_STORAGE_PATH=file:/tmp/dados_abertos_camara

# Caminhos por camada
BRONZE_PATH=${BASE_STORAGE_PATH}/bronze
SILVER_PATH=${BASE_STORAGE_PATH}/silver
GOLD_PATH=${BASE_STORAGE_PATH}/gold
STAR_PATH=${BASE_STORAGE_PATH}/star
MONITORING_PATH=${BASE_STORAGE_PATH}/monitoring
CHECKPOINT_PATH=${BASE_STORAGE_PATH}/checkpoints
ML_ARTIFACTS_PATH=${BASE_STORAGE_PATH}/ml_artifacts


# ============================================================
# Schemas / Catálogos
# ============================================================

# Catálogo usado em ambiente Databricks/Unity Catalog, se aplicável
DATABRICKS_CATALOG=dados_abertos

# Schemas lógicos por camada
BRONZE_SCHEMA=dados_abertos.bronze
SILVER_SCHEMA=dados_abertos.silver
GOLD_SCHEMA=dados_abertos.gold
STAR_SCHEMA=dados_abertos.star_schema
MONITORING_SCHEMA=dados_abertos.monitoring

# Schema final para publicação de tabelas consumidas no Power BI
SERVING_SCHEMA=dados_abertos.star_schema


# ============================================================
# Azure Data Lake / Databricks
# ============================================================

# Estas variáveis são exemplos.
# Em produção, recomenda-se usar Databricks Secrets ou Azure Key Vault.

AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_CONTAINER_NAME=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Exemplo de chave de storage, caso aplicável.
# Evite usar em produção se puder usar service principal ou managed identity.
AZURE_STORAGE_ACCOUNT_KEY=


# ============================================================
# Spark
# ============================================================

SPARK_APP_NAME=dados-abertos-camara-lakehouse

# Número de partições shuffle.
# Para desenvolvimento local, mantenha baixo.
SPARK_SQL_SHUFFLE_PARTITIONS=8

# Timezone Spark
SPARK_SQL_SESSION_TIMEZONE=America/Sao_Paulo

# Habilitar otimizações Delta, quando suportado pelo ambiente
SPARK_DELTA_OPTIMIZE_WRITE=true
SPARK_DELTA_AUTO_COMPACT=true


# ============================================================
# Delta Lake
# ============================================================

# Modo padrão de escrita: overwrite, append ou merge
DEFAULT_WRITE_MODE=overwrite

# Permitir evolução de schema em escritas Delta
DELTA_SCHEMA_MERGE_ENABLED=true

# Habilitar optimize após escrita, se suportado
DELTA_OPTIMIZE_ENABLED=false

# Habilitar vacuum após escrita, se suportado
DELTA_VACUUM_ENABLED=false

# Retenção do vacuum em horas
DELTA_VACUUM_RETENTION_HOURS=168


# ============================================================
# Pipeline
# ============================================================

# Se true, o pipeline para ao encontrar erro em um dataset
PIPELINE_STOP_ON_ERROR=true

# Se true, coleta contagem de registros para logs.
# Em produção, pode ser false para reduzir custo de execução Spark.
PIPELINE_ENABLE_RECORD_COUNT=true

# Quantidade máxima de IDs pais em ingestões dependentes.
# Útil para controlar volume em desenvolvimento.
PIPELINE_MAX_PARENT_IDS=1000

# Data inicial padrão para cargas incrementais
PIPELINE_DEFAULT_START_DATE=2023-01-01

# Data final opcional para cargas incrementais.
# Deixe vazio para usar a data atual.
PIPELINE_DEFAULT_END_DATE=


# ============================================================
# Data Quality
# ============================================================

# Habilita validações formais de Data Quality
DATA_QUALITY_ENABLED=true

# Se true, falhas com severidade error interrompem o pipeline
DATA_QUALITY_FAIL_ON_ERROR=true

# Se true, salva resultados de qualidade em tabela de monitoramento
DATA_QUALITY_SAVE_RESULTS=true

# Nome da tabela de resultados de Data Quality
DATA_QUALITY_RESULTS_TABLE=data_quality_results


# ============================================================
# Logging / Observabilidade
# ============================================================

# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Salvar logs estruturados em Delta
LOG_TO_DELTA=true

# Nome da tabela de logs do pipeline
PIPELINE_LOG_TABLE=pipeline_logs

# Nome da tabela de watermarks
WATERMARK_TABLE=watermarks


# ============================================================
# MLflow
# ============================================================

# Tracking URI do MLflow.
#
# Exemplos:
# local: ./mlruns
# Databricks: databricks
#
MLFLOW_TRACKING_URI=./mlruns

# Nome do experimento MLflow
MLFLOW_EXPERIMENT_NAME=/dados_abertos_camara/classificacao_legislativa

# Nome registrado do modelo de tema
MLFLOW_TEMA_MODEL_NAME=camara_tema_classifier

# Nome registrado do modelo de natureza jurídica
MLFLOW_NATUREZA_MODEL_NAME=camara_natureza_classifier

# Alias padrão usado para inferência
MLFLOW_MODEL_ALIAS=champion


# ============================================================
# ML / NLP
# ============================================================

# Habilitar inferência ML na camada Gold
ML_INFERENCE_ENABLED=true

# Threshold mínimo de confiança para aceitar predição de tema
ML_TEMA_MIN_CONFIDENCE=0.60

# Threshold mínimo de margem entre primeira e segunda classe de tema
ML_TEMA_MIN_MARGIN=0.10

# Threshold mínimo de confiança para aceitar predição de natureza jurídica
ML_NATUREZA_MIN_CONFIDENCE=0.60

# Percentual de teste no treinamento
ML_TEST_SIZE=0.20

# Seed para reprodutibilidade
ML_RANDOM_STATE=42

# Número máximo de features TF-IDF
ML_TFIDF_MAX_FEATURES=5000

# N-grams usados no TF-IDF
ML_TFIDF_NGRAM_MIN=1
ML_TFIDF_NGRAM_MAX=2


# ============================================================
# Serving / Power BI
# ============================================================

# Habilitar publicação das tabelas finais
SERVING_ENABLED=true

# Se true, recria o schema de serving antes de publicar
SERVING_RECREATE_SCHEMA=false

# Formato de publicação: delta, table ou view
SERVING_MODE=table


# ============================================================
# Execução local
# ============================================================

# Define se o projeto deve rodar em modo local.
# Útil para testes fora do Databricks.
LOCAL_MODE=true

# Caminho local para dados temporários
LOCAL_DATA_PATH=/tmp/dados_abertos_camara

# Caminho local para artefatos de ML
LOCAL_ML_ARTIFACTS_PATH=/tmp/dados_abertos_camara/ml_artifacts


# ============================================================
# Segurança
# ============================================================

# Nunca preencher segredos reais neste arquivo exemplo.
# Crie um arquivo .env local e mantenha-o fora do Git.
SECRET_EXAMPLE_DO_NOT_USE=replace_me